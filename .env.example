DATABASE_URL=your_database_url_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
JWT_SECRET=your_jwt_secret_here
CLIENT_URL=http://localhost:5173
# Optional, comma-separated extra origins for CORS and Socket.IO
CLIENT_URLS=http://localhost:5173,https://biteyo-fe.vercel.app
PORT=8000
EMAIL_USER=your_email_here
EMAIL_PASS=your_email_password_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_REDIRECT_URI=your_google_redirect_uri_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local fallback path when FIREBASE_SERVICE_ACCOUNT_KEY is not set
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Use this in Vercel/production instead of committing the JSON file
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your_project_id"}
NODE_ENV=development
